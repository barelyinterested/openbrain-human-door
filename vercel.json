{
  "version": 2,
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/vercel.cjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
